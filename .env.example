# Root Environment Variables
# This file contains example environment variables for the entire project

# Development
NODE_ENV=development

# Database (shared)
DATABASE_URL="postgresql://postgres:password@localhost:5434/KANAKU"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-min-32-characters-long"

# Frontend
VITE_APP_URL="http://localhost:9002"  # Your app URL (change to production URL when deploying)
VITE_API_BASE_URL="/api/v1"
VITE_API_URL="/api/v1"
VITE_API_PROXY_TARGET="http://localhost:3000"
VITE_SOCKET_URL="http://localhost:3000"
VITE_ENABLE_REALTIME="true"
VITE_ENABLE_NOTIFICATIONS="true"
VITE_ENABLE_DEMO_DATA="false"  # Set to "true" to populate demo data for new users
VITE_ALLOW_DIRECT_BACKEND_FALLBACK="false"  # Set "true" only if browser should call localhost:3000 directly

# Backend
PORT=3000
LOG_LEVEL=info
FRONTEND_URL="http://localhost:9002"

# Docker
POSTGRES_PASSWORD="password"
POSTGRES_DB="KANAKU"

# API Keys and Credentials
# Add your API keys here when needed
# STRIPE_API_KEY="your_stripe_api_key"
# OPENAI_API_KEY="your_openai_api_key"
# GOOGLE_API_KEY="your_google_api_key"
# FIREBASE_SECRET="your_firebase_secret"
# AWS_SECRET_ACCESS_KEY="your_aws_secret"
# SENDGRID_API_KEY="your_sendgrid_api_key"
# VITE_STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key"
# VITE_GOOGLE_CLIENT_ID="your_google_client_id"
# VITE_FIREBASE_API_KEY="your_firebase_api_key"

