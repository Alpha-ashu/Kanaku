{
  "version": 2,
  "name": "KANAKU",
  "buildCommand": "npm install --prefix backend && npm run project:build",
  "outputDirectory": "dist",
  "functions": {
    "api/*.ts": {
      "maxDuration": 30,
      "includeFiles": "backend/{dist/**,generated/**,prisma/**,eng.traineddata}"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/assets/(.*)",
      "status": 404
    },
    {
      "src": "/api/v1/stocks$",
      "dest": "/api/stocks.ts"
    },
    {
      "src": "/api/v1/stocks/(.*)",
      "dest": "/api/stocks.ts?endpoint=$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/health",
      "dest": "/api/health.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "regions": [
    "iad1"
  ]
}
