{
  "version": 2,
  "name": "kanaku",
  "buildCommand": "npm run build:frontend",
  "outputDirectory": "dist",
  "regions": ["sin1", "iad1"],
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/assets/(.*)",
      "status": 404
    },
    {
      "src": "/api/v1/stocks$",
      "dest": "/api/stocks.ts"
    },
    {
      "src": "/api/v1/stocks/(.*)",
      "dest": "/api/stocks.ts?endpoint=$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://kanaku.fly.dev/api/$1"
    },
    {
      "src": "/health",
      "dest": "https://kanaku.fly.dev/health"
    },
    {
      "src": "/socket.io/(.*)",
      "dest": "https://kanaku.fly.dev/socket.io/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "functions": {
    "api/stocks.ts": {
      "maxDuration": 15
    }
  }
}
