VITE_API_URL=/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_anon_key

# Required: base URL of the backend API (e.g. https://api.yourapp.com)
VITE_API_BASE_URL=

# Required: encryption key for local IndexedDB backups (set a strong random secret)
VITE_DB_ENCRYPTION_KEY=

# Required: contact emails shown to users on marketing pages
VITE_SUPPORT_EMAIL=
VITE_LEGAL_EMAIL=

# Optional: mobile app store links (leave empty if not published yet)
VITE_IOS_APP_STORE_URL=
VITE_ANDROID_APP_STORE_URL=

# Optional: direct browser fallback for live market data when the backend
# stock service is unavailable.
VITE_TWELVEDATA_API_KEY=your_twelvedata_api_key
VITE_TWELVEDATA_BASE_URL=https://api.twelvedata.com

# Optional: override the local backend target used by the Vite dev proxy.
VITE_API_PROXY_TARGET=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000

# Optional: allow browser-side fallback calls to localhost/127.0.0.1 backend when
# proxy endpoint fails. Keep false to reduce repeated ERR_CONNECTION_REFUSED noise.
VITE_ALLOW_DIRECT_BACKEND_FALLBACK=false

# Roles and PIN state are backend-authoritative. Do not add client-only role or PIN flags here.
