{
  "name": "KANKU",
  "private": true,
  "version": "1.0.0",
  "description": "A comprehensive personal finance management platform",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-full.mjs",
    "dev:frontend": "vite",
    "dev:backend": "cd backend && npm run dev",
    "dev:full": "node scripts/dev-full.mjs",
    "project:build": "node --max-old-space-size=4096 node_modules/vite/bin/vite.js build && node --max-old-space-size=4096 node_modules/typescript/bin/tsc -p backend/tsconfig.json",
    "build:backend": "node --max-old-space-size=4096 node_modules/typescript/bin/tsc -p backend/tsconfig.json",
    "build:frontend": "node --max-old-space-size=4096 node_modules/vite/bin/vite.js build",
    "build:pwa": "vite build && npx cap sync",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:migrate": "cd backend && npx prisma@6.19.2 migrate dev",
    "db:seed": "cd backend && npx prisma@6.19.2 db seed",
    "db:studio": "cd backend && npx prisma@6.19.2 studio",
    "db:generate": "npx prisma@6.19.2 generate --schema backend/prisma/schema.prisma",
    "cap:init": "npx cap init",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "test": "vitest --config frontend/vitest.config.ts",
    "test:ui": "vitest --config frontend/vitest.config.ts --ui",
    "test:coverage": "vitest --config frontend/vitest.config.ts --coverage",
    "qa:backend:seed": "npm --prefix backend run qa:seed-admin",
    "qa:backend:matrix": "npm --prefix backend run qa:matrix",
    "qa:backend": "npm --prefix backend run qa:test-features",
    "clean": "rimraf dist node_modules/.vite",
    "postinstall": "npm run db:generate"
  },
