{
  "name": "kanaku",
  "private": true,
  "version": "1.0.0",
  "description": "A comprehensive personal finance management platform (npm workspaces monorepo)",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "node scripts/dev-full.mjs",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "build": "npm run build:backend && npm run build:frontend",
    "build:frontend": "npm run build --workspace frontend",
    "build:backend": "npm run build --workspace backend",
    "build:pwa": "npm run build:frontend && npx cap sync",
    "preview": "npm run preview --workspace frontend",
    "lint": "npm run lint --workspaces --if-present",
    "type-check": "npm run type-check --workspace frontend",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "docs:modules": "node scripts/gen-module-readmes.mjs",
    "docs:frontend": "node scripts/gen-frontend-readmes.mjs",
    "docs:catalogs": "node scripts/gen-catalogs.mjs",
    "docs:endpoints": "node scripts/gen-endpoint-docs.mjs",
    "test": "npm run test:unit --workspace frontend",
    "test:backend": "npm run test --workspace backend",
    "test:e2e": "playwright test",
    "test:api": "playwright test -c quality/api/e2e/playwright.api.config.ts",
    "db:migrate": "cd backend && npx prisma@6.19.2 migrate dev",
    "db:seed": "cd backend && npx prisma@6.19.2 db seed",
    "db:studio": "cd backend && npx prisma@6.19.2 studio",
    "db:generate": "npx prisma@6.19.2 generate --schema backend/prisma/schema.prisma",
    "cap:init": "npx cap init",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "qa:backend:seed": "npm --prefix backend run qa:seed-admin",
    "qa:backend:matrix": "npm --prefix backend run qa:matrix",
    "qa:backend": "npm --prefix backend run qa:test-features",
    "qa:api-report": "node quality/api/runner/run-api-report.mjs",
    "qa:ui-inventory": "node scripts/gen-ui-inventory.mjs",
    "qa:ui-fix": "node scripts/fix-ui-testids.mjs",
    "qa:contract-audit": "node scripts/audit-api-contracts.mjs",
    "qa:contract-enrich": "node scripts/enrich-api-contracts.mjs",
    "qa:regression": "node scripts/qa-regression-diff.mjs",
    "qa:reports": "npm run qa:ui-inventory && npm run qa:contract-audit",
    "clean": "rimraf frontend/dist backend/dist node_modules/.vite",
    "postinstall": "npm run db:generate"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.2",
    "@capacitor/cli": "^8.0.2",
    "@playwright/test": "^1.60.0",
    "@vercel/node": "^5.8.17",
    "ajv": "^6.14.0",
    "prisma": "^6.19.3",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "rollup": "^4.62.0",
    "tar": "^7.5.16",
    "socket.io-parser": "^4.2.6",
    "form-data": "^4.0.6",
    "minimatch": "^10.2.4",
    "@typescript-eslint/typescript-estree": {
      "minimatch": "^10.2.4"
    },
    "dompurify": "^3.4.11",
    "flatted": "^3.4.2",
    "path-to-regexp": "^8.4.2",
    "express": {
      "path-to-regexp": "^0.1.13"
    },
    "picomatch": "^2.3.2 || ^4.0.4",
    "defu": "^6.1.5",
    "effect": "^3.20.0",
    "lodash": "^4.18.0",
    "qs": "^6.15.2",
    "@xmldom/xmldom": "^0.9.10",
    "ws": "^8.21.0",
    "follow-redirects": "^1.16.0",
    "undici": "^7.28.0",
    "handlebars": "^4.7.9",
    "ajv": "^6.14.0",
    "eslint": {
      "ajv": "^6.14.0"
    },
    "@eslint/eslintrc": {
      "ajv": "^6.14.0"
    },
    "@vercel/static-config": {
      "ajv": "^8.18.0"
    },
    "esbuild": "^0.28.1",
    "ip-address": "^10.2.0",
    "js-yaml": "^4.1.2",
    "yaml": "^2.8.3 || ^1.10.3",
    "protobufjs": "^7.6.3 || ^8.6.0",
    "@babel/core": "^7.29.6",
    "@tootallnate/once": "^2.0.1 || ^3.0.1",
    "smol-toml": "^1.6.1",
    "nodemailer": "^9.0.1",
    "axios": "^1.18.0",
    "postcss": "^8.5.15",
    "uuid": "^14.0.0",
    "file-type": "^22.0.1",
    "vite": "8.0.16",
    "@emnapi/core": "1.11.1",
    "@emnapi/runtime": "1.11.1",
    "@emnapi/wasi-threads": "1.2.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "motion": "12.40.0",
    "framer-motion": "12.40.0",
    "motion-dom": "12.40.0",
    "motion-utils": "12.39.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "8.0.16"
    }
  }
}
