{
    "name":  "KANAKU-backend",
    "version":  "1.0.0",
    "description":  "Backend API for KANAKU with TypeScript, Express, Prisma, JWT, Socket.IO",
    "type":  "commonjs",
    "main":  "dist/server.js",
    "scripts":  {
                    "dev":  "ts-node-dev --respawn --transpile-only src/server.ts",
                    "generate:prisma":  "prisma generate",
                    "db:test:reset":  "node ./scripts/test-db.mjs",
                    "ensure:cloud-sync-schema":  "node ./scripts/ensure-cloud-sync-schema.cjs",
                    "ensure:db-integrity":  "node ./scripts/ensure-db-integrity.cjs",
                    "backfill:user-settings":  "node ./scripts/backfill-user-settings.cjs",
                    "backfill:profiles-from-user":  "node ./scripts/backfill-profiles-from-user.cjs",
                    "demo:reset-users":  "node ./scripts/reset-demo-users.cjs",
                    "measure:auth":  "node ./scripts/measure-auth-distribution.cjs",
                    "migrate:supabase-auth":  "node ./scripts/migrate-users-to-supabase-auth.cjs",
                    "seed:demo":  "node ./scripts/seed-production-roles.cjs \u0026\u0026 node ./scripts/seed-mock-data.cjs",
                    "seed:test":  "node ./scripts/seed-test-users.cjs",
                    "seed:all":  "npm run seed:demo && npm run seed:test",
                    "build":  "tsc",
                    "start":  "node dist/server.js",
                    "test":  "jest",
                    "test:smoke":  "jest --runInBand tests/integration/smoke.test.ts",
                    "test:sanity":  "jest --runInBand tests/integration/sanity.test.ts",
                    "test:regression":  "jest --runInBand tests/integration/regression.test.ts",
                    "test:unit":  "jest --runInBand tests/integration/auth.test.ts tests/integration/accounts.test.ts tests/integration/transactions.test.ts tests/integration/goals.test.ts tests/integration/loans.test.ts tests/integration/dashboard.test.ts tests/integration/investments.test.ts tests/integration/notifications.test.ts tests/integration/settings.test.ts tests/integration/friends-groups.test.ts tests/integration/todos.test.ts",
                    "test:security":  "jest --runInBand tests/integration/security.test.ts tests/integration/ai-security.test.ts tests/integration/bills-security.test.ts",
                    "test:ai:security":  "jest --runInBand tests/integration/ai-security.test.ts",
                    "test:security:critical":  "jest --runInBand tests/integration/security.test.ts tests/integration/transactions.test.ts tests/integration/bills-security.test.ts",
                    "test:all":  "jest --runInBand",
                    "test:coverage":  "jest --coverage",
                    "qa:seed-admin":  "node ./scripts/seed-admin-feature-data.cjs",
                    "qa:matrix":  "powershell -ExecutionPolicy Bypass -File ./scripts/run-feature-matrix.ps1",
                    "qa:test-features":  "npm run qa:seed-admin \u0026\u0026 powershell -ExecutionPolicy Bypass -File ./scripts/run-feature-matrix-with-server.ps1",
                    "test:watch":  "jest --watch",
                    "lint":  "eslint src --ext .ts",
                    "lint:fix":  "eslint src --ext .ts --fix",
                    "schemas:scaffold":  "powershell -ExecutionPolicy Bypass -File scripts/scaffold-feature-schemas.ps1"
                },
    "keywords":  [
                     "KANAKU",
                     "expense-tracker",
                     "typescript",
                     "express",
                     "prisma",
                     "jwt",
                     "socket.io"
                 ],
    "author":  "Your Name",
    "license":  "MIT",
    "engines":  {
                    "node":  "\u003e=18.0.0",
                    "npm":  "\u003e=8.0.0"
                },
    "dependencies":  {
                         "@google/generative-ai":  "^0.24.1",
                         "@prisma/client":  "^6.19.2",
                         "@sendgrid/mail":  "^8.1.5",
                         "@supabase/supabase-js":  "^2.95.3",
                         "bcrypt":  "^6.0.0",
                         "bcryptjs":  "^2.4.3",
                         "bullmq":  "^5.77.6",
                         "cors":  "^2.8.5",
                         "csv-parse":  "^5.5.3",
                         "dotenv":  "^16.6.1",
                         "exceljs":  "^4.4.0",
                         "express":  "^4.22.1",
                         "file-type":  "^22.0.1",
                         "firebase-admin":  "^13.10.0",
                         "helmet":  "^8.1.0",
                         "ioredis":  "^5.8.1",
                         "jose":  "^5.4.3",
                         "jsonwebtoken":  "^9.0.3",
                         "multer":  "^2.2.0",
                         "node-cron":  "^4.2.1",
                         "nodemailer":  "^9.0.1",
                         "pdf-parse":  "^1.1.1",
                         "pg":  "^8.20.0",
                         "redis":  "^6.0.0",
                         "sharp":  "^0.33.5",
                         "socket.io":  "^4.7.4",
                         "sqlite3":  "^5.1.7",
                         "tesseract.js":  "^7.0.0",
                         "tsx":  "^4.21.0",
                         "tweetnacl":  "^1.0.3",
                         "tweetnacl-util":  "^0.15.1",
                         "uuid":  "^14.0.0",
                         "winston":  "^3.19.0",
                         "zod":  "^3.23.8"
                     },
    "devDependencies":  {
                            "@prisma/internals":  "^7.3.0",
                            "@types/cors":  "^2.8.17",
                            "@types/dotenv":  "^8.2.0",
                            "@types/express":  "^4.17.21",
                            "@types/jest":  "^29.5.11",
                            "@types/jsonwebtoken":  "^9.0.6",
                            "@types/multer":  "^1.4.12",
                            "@types/node":  "^20.11.5",
                            "@types/supertest":  "^6.0.3",
                            "@typescript-eslint/eslint-plugin":  "^6.21.0",
                            "@typescript-eslint/parser":  "^6.21.0",
                            "eslint":  "^8.56.0",
                            "jest":  "^29.7.0",
                            "jest-environment-node":  "^29.7.0",
                            "prisma":  "^6.19.2",
                            "supertest":  "^6.3.3",
                            "ts-jest":  "^29.1.1",
                            "ts-node-dev":  "^2.0.0",
                            "typescript":  "~5.9.3"
                        },
    "overrides":  {
                      "tar":  "^7.5.16",
                      "socket.io-parser":  "^4.2.6",
                      "form-data":  "^4.0.6",
                      "minimatch":  "^10.2.4",
                      "@typescript-eslint/typescript-estree": {
                        "minimatch": "^10.2.4"
                      },
                      "flatted":  "^3.4.2",
                      "path-to-regexp":  "^0.1.13",
                      "picomatch":  "^2.3.2 || ^4.0.4",
                      "defu":  "^6.1.5",
