                      "follow-redirects":  "^1.16.0",
                      "undici":  "^6.24.0",
                      "handlebars":  "^4.7.9",
                      "ajv":  "^6.14.0",
                      "esbuild":  "^0.28.1",
                      "ip-address":  "^10.2.0",
                      "js-yaml":  "^4.1.2",
                      "yaml":  "^2.8.3 || ^1.10.3",
                      "protobufjs":  "^7.6.3 || ^8.6.0",
                      "@babel/core":  "^7.29.6",
                      "@tootallnate/once":  "^2.0.1 || ^3.0.1",
                      "smol-toml":  "^1.6.1",
                      "nodemailer":  "^9.0.1",
                      "axios":  "^1.18.0",
                      "postcss":  "^8.5.15",
                      "uuid":  "^14.0.0",
                      "file-type":  "^22.0.1"
                  }
}
