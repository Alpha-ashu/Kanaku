# Environment
NODE_ENV=development
PORT=3000

# ── Phase-gated modules ────────────────────────────────────────────────────────
# Comma-separated allowlist of deferred, later-phase routers to MOUNT. Anything
# not listed here is left unmounted and its routes return 404 — so deferred /
# regulated endpoints (advisor marketplace, payments, Account Aggregator) cannot
# be reached just because their code exists in the repo. Leave UNSET in production
# until a module's phase ships. MVP modules are always mounted regardless.
# Recognized keys: advisor, payments, aa
# ENABLED_MODULES=advisor,payments,aa

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5434/expense_tracker"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-min-32-characters-long"
# Required for verifying Supabase-issued JWTs on the backend (found in Supabase Dashboard > Settings > API > JWT Secret)
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"
# Signs the short-lived step-up "security token" (PIN/biometric gate). Falls back to JWT_SECRET if unset.
SECURITY_JWT_SECRET=""
# Keys the OTP HMAC so a DB read alone can't brute-force the 6-digit OTP space. Falls back to JWT_SECRET if unset; set an independent value in production.
OTP_HMAC_SECRET=""

# Server-side inactivity window (minutes). After this long with no authenticated
# request, the session is treated as idle: API calls AND token refresh are
# rejected with 401 SESSION_IDLE_TIMEOUT, so a stolen access/refresh token can't
# be replayed after the user walked away. 0 / unset disables it. Recommended
# slightly higher than the client auto-lock (5 min) so users lock locally first.
# Stored in-process (single backend instance) — no Redis required.
IDLE_TIMEOUT_MINUTES=10

# ── API / Worker split (Fly process groups) ────────────────────────────────────
# Background jobs (notification outbox, AI tasks, cleanup) run in a dedicated
# worker process (dist/worker.js / `npm run worker`). Set RUN_WORKERS_IN_API=false
# on the PUBLIC API process so it serves requests only and never runs jobs — a
# slow/failing job then cannot affect API responsiveness. The worker process
# always runs the jobs regardless of this flag.
# Leave UNSET for local dev / single-machine prod: the API runs jobs in-process
# exactly as before (combined mode), so behaviour is unchanged.
# RUN_WORKERS_IN_API=false
#
# Worker health monitoring: the worker process serves an internal-only health
# endpoint (GET /health → 200 ok|starting / 503 stale) probed by Fly's machine
# check. Not publicly routed. Defaults shown:
# WORKER_HEALTH_PORT=9090       # internal health server port (worker only)
# WORKER_HEALTH_STALE_MS=90000  # mark worker stale if outbox hasn't drained in this window

# ── Notification delivery (DB outbox, Redis-free) ──────────────────────────────
# Email/push are NOT sent through a queue/broker. Producers write a notification
# row at status='pending'; a node-cron drainer polls and delivers via SendGrid/FCM,
# retrying with exponential backoff (status pending→processing→sent|retrying|failed).
# All optional — sane defaults apply when unset:
# NOTIFICATION_OUTBOX_CRON="*/15 * * * * *"   # 6-field cron (seconds); default every 15s
# NOTIFICATION_OUTBOX_BATCH=25                # rows processed per tick
# NOTIFICATION_MAX_ATTEMPTS=5                 # retries before a row lands at status='failed'
# CACHE_MAX_ENTRIES=50000                     # cap on the in-process cache before LRU eviction

# Payments
# Shared secret for payment provider webhooks. The webhook verifies an HMAC-SHA256
# signature over the raw body (header: x-webhook-signature, "sha256=<hex>"), and
# falls back to a constant-time shared-secret header (x-payment-webhook-secret).
PAYMENT_WEBHOOK_SECRET=""

# Frontend
FRONTEND_URL="http://localhost:9002"
# Comma-separated list of allowed origins. Use "*" to allow all.
# Example: CORS_ORIGIN="http://localhost:9002,https://your-app.vercel.app"
CORS_ORIGIN=""

# Logging
LOG_LEVEL=info

# Supabase Storage
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="secure-uploads"
SUPABASE_SIGNED_URL_TTL=600

# Upload Limits
UPLOAD_MAX_BYTES=10485760
UPLOAD_IMAGE_MAX_DIMENSION=2000
UPLOAD_IMAGE_QUALITY=82
UPLOAD_RATE_LIMIT=15

# Malware Scanning (ClamAV)
CLAMAV_HOST=""
CLAMAV_PORT=3310
CLAMAV_REQUIRED=false

# Image Moderation
MODERATION_WEBHOOK_URL=""
MODERATION_REQUIRED=false

# API Keys and Credentials
SENDGRID_API_KEY="your_sendgrid_api_key"
# Verified SendGrid sender email (must be verified in your SendGrid account)
SENDGRID_FROM_EMAIL="your_verified_sender@example.com"
# ECDSA public key (base64 or PEM) for verifying SendGrid Event Webhook signatures.
# Found in SendGrid > Settings > Mail Settings > Signed Event Webhook > Verification Key.
# REQUIRED in production — the /api/v1/webhooks/sendgrid route fails closed without it.
SENDGRID_WEBHOOK_PUBLIC_KEY=""

# Public API URL (used in Swagger/OpenAPI docs server list)
API_PUBLIC_URL=""
# Contact email shown in API docs
API_CONTACT_EMAIL=""

# Account Aggregator (Setu AA) integration â€” leave empty if not using AA feature
AA_BASE_URL="https://aa-sandbox.setu.co"
AA_CLIENT_ID=""
AA_CLIENT_SECRET=""
AA_REDIRECT_URL=""
AA_FIU_ID=""

# Optional â€” other API keys
# STRIPE_API_KEY="your_stripe_api_key"
# OPENAI_API_KEY="your_openai_api_key"
# GOOGLE_API_KEY="your_google_api_key"

# Demo / Seed Account Credentials
# Used by scripts/seed-production-roles.cjs â€” set via `fly secrets set` in production
# SEED_ADMIN_EMAIL=admin@kanku.com
# SEED_ADMIN_PASSWORD=<see team password vault>
# SEED_MANAGER_EMAIL=manager@kanku.com
# SEED_MANAGER_PASSWORD=<see team password vault>
# SEED_ADVISOR_EMAIL=advisor@kanku.com
# SEED_ADVISOR_PASSWORD=<see team password vault>
# SEED_USER_EMAIL=user@kanku.com
# SEED_USER_PASSWORD=<see team password vault>
