# Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5434/expense_tracker"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-min-32-characters-long"
# Required for verifying Supabase-issued JWTs on the backend (found in Supabase Dashboard > Settings > API > JWT Secret)
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# Frontend
FRONTEND_URL="http://localhost:9002"
# Comma-separated list of allowed origins. Use "*" to allow all.
# Example: CORS_ORIGIN="http://localhost:9002,https://your-app.vercel.app"
CORS_ORIGIN=""

# Logging
LOG_LEVEL=info

# Supabase Storage
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="secure-uploads"
SUPABASE_SIGNED_URL_TTL=600

# Upload Limits
UPLOAD_MAX_BYTES=10485760
UPLOAD_IMAGE_MAX_DIMENSION=2000
UPLOAD_IMAGE_QUALITY=82
UPLOAD_RATE_LIMIT=15

# Malware Scanning (ClamAV)
CLAMAV_HOST=""
CLAMAV_PORT=3310
CLAMAV_REQUIRED=false

# Image Moderation
MODERATION_WEBHOOK_URL=""
MODERATION_REQUIRED=false

# API Keys and Credentials
# Add your API keys here when needed
# STRIPE_API_KEY="your_stripe_api_key"
# OPENAI_API_KEY="your_openai_api_key"
# GOOGLE_API_KEY="your_google_api_key"
# FIREBASE_SECRET="your_firebase_secret"
# AWS_SECRET_ACCESS_KEY="your_aws_secret"
# SENDGRID_API_KEY="your_sendgrid_api_key"

# Demo / Seed Account Credentials
# Used by scripts/seed-production-roles.cjs — set via `fly secrets set` in production
# SEED_ADMIN_EMAIL=admin@kanku.com
# SEED_ADMIN_PASSWORD=<see team password vault>
# SEED_MANAGER_EMAIL=manager@kanku.com
# SEED_MANAGER_PASSWORD=<see team password vault>
# SEED_ADVISOR_EMAIL=advisor@kanku.com
# SEED_ADVISOR_PASSWORD=<see team password vault>
# SEED_USER_EMAIL=user@kanku.com
# SEED_USER_PASSWORD=<see team password vault>
