generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

model Account {
  id                String             @id @default(uuid())
  userId            String
  deviceId          String?
  name              String
  type              String             @default("bank")
  provider          String?
  country           String?
  balance           Decimal            @default(0) @db.Decimal(12, 2) // Computed by trigger from transactions
  currency          String             @default("USD")
  isActive          Boolean            @default(true)
  syncStatus        String             @default("synced")
  clientRequestId   String?            @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalContributions GoalContribution[]
  transactions      Transaction[]
  groupExpenses     GroupExpense[]

  @@index([isActive])
  @@index([syncStatus])
  @@index([userId])
  @@index([createdAt])
  @@index([deletedAt])
  @@schema("public")
}

model AdvisorAvailability {
  id        String   @id @default(uuid())
  advisorId String
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  advisor   User     @relation(fields: [advisorId], references: [id], onDelete: Cascade)

  @@index([advisorId])
  @@schema("public")
}

model AdvisorSession {
  id           String         @id @default(uuid())
  bookingId    String         @unique
  advisorId    String
  clientId     String
  startTime    DateTime
  endTime      DateTime?
  sessionType  String
  status       String         @default("scheduled")
  notes        String?
  rating       Float?
  feedback     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  advisor      User           @relation("AdvisorSession_advisorIdToUser", fields: [advisorId], references: [id], onDelete: Cascade)
  booking      BookingRequest @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  client       User           @relation("AdvisorSession_clientIdToUser", fields: [clientId], references: [id], onDelete: Cascade)
  chatMessages ChatMessage[]
  payment      Payment?

  @@index([advisorId])
  @@index([clientId])
  @@index([startTime])
  @@index([status])
  @@schema("public")
}

model BookingRequest {
  id              String          @id @default(uuid())
  clientId        String
  advisorId       String
  sessionType     String
  description     String?
  proposedDate    DateTime
  proposedTime    String
  duration        Int
  amount          Decimal         @db.Decimal(12, 2)
  status          String          @default("pending")
  rejectionReason String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  session         AdvisorSession?
  advisor         User            @relation("BookingRequest_advisorIdToUser", fields: [advisorId], references: [id], onDelete: Cascade)
  client          User            @relation("BookingRequest_clientIdToUser", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([advisorId])
  @@index([clientId])
  @@index([proposedDate])
  @@index([status])
  @@schema("public")
}

model Category {
  id                String    @id @default(uuid())
  userId            String
  name              String
  type              String
  color             String
  icon              String
  createdFromImport Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name, type])
  @@index([type])
  @@index([userId])
  @@schema("public")
}

model ChatMessage {
  id        String         @id @default(uuid())
  sessionId String
  senderId  String
  message   String
  timestamp DateTime       @default(now())
  sender    User           @relation(fields: [senderId], references: [id], onDelete: Cascade)
  session   AdvisorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([sessionId])
  @@index([timestamp])
  @@schema("public")
}

model Device {
  id           String    @id @default(uuid())
  userId       String
  deviceId     String    @unique
  deviceName   String?
  deviceType   String?
  platform     String?
  appVersion   String?
  isActive     Boolean   @default(true)
  isTrusted    Boolean   @default(false)
  lastSeenAt   DateTime  @default(now())
  // Notification System Fields
  fcmToken     String? // Firebase Cloud Messaging token for push notifications
  publicKey    String? // Optional public key for E2E encryption (TweetNaCl format)
  osType       String?
  osVersion    String?
  apnsToken    String?
  lastSyncedAt DateTime? @default(now())
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId], name: "userId_deviceId")
  @@index([deviceId])
  @@index([isActive])
  @@index([userId])
  @@index([fcmToken])
  @@index([userId, isActive]) // active device lookup for push notifications
  @@schema("public")
}

model ExpenseBill {
  id               String   @id @default(uuid())
  userId           String
  transactionId    String?
  originalName     String
  contentType      String
  size             Int
  storagePath      String
  sha256           String
  scanStatus       String   @default("pending")
  scanResult       String?
  moderationStatus String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sha256])
  @@index([transactionId])
  @@index([userId])
  @@schema("public")
}

model Friend {
  id         String    @id @default(uuid())
  userId     String
  deviceId   String?
  name       String
  email      String?
  phone      String?
  avatar     String?
  notes      String?
  syncStatus String    @default("synced")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([syncStatus])
  @@index([userId])
  @@schema("public")
}

model Goal {
  id                String             @id @default(uuid())
  userId            String
  deviceId          String?
  name              String
  description       String?
  targetAmount      Decimal            @db.Decimal(12, 2)
  currentAmount     Decimal            @default(0) @db.Decimal(12, 2)
  targetDate        DateTime
  category          String?
  isGroupGoal       Boolean            @default(false)
  syncStatus        String             @default("synced")
  clientRequestId   String?            @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalContributions GoalContribution[]

  @@index([syncStatus])
  @@index([targetDate])
  @@index([userId])
  @@index([createdAt])
  @@index([deletedAt])
  @@schema("public")
}

model GoalContribution {
  id         String   @id @default(uuid())
  userId     String
  goalId     String
  accountId  String
  amount     Decimal  @db.Decimal(12, 2)
  date       DateTime
  memberName String?
  status     String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  goal       Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([date])
  @@index([goalId])
  @@index([userId])
  @@schema("public")
}

model ImportLog {
  id                String   @id @default(uuid())
  userId            String
  fileName          String
  fileType          String
  sourceKind        String
  totalRecords      Int
  importedRecords   Int
  skippedRecords    Int
  duplicateRecords  Int
  createdCategories Json     @default("[]")
  createdAccounts   Json     @default("[]")
  createdGoals      Json     @default("[]")
  updatedGoals      Json     @default("[]")
  failedRecords     Int      @default(0)
  errors            Json     @default("[]")
  metadata          String?
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([sourceKind])
  @@index([userId])
  @@schema("public")
}

model Investment {
  id              String    @id @default(uuid())
  userId          String
  assetType       String
  assetName       String
  quantity        Decimal   @db.Decimal(12, 4)
  buyPrice        Decimal   @db.Decimal(12, 2)
  currentPrice    Decimal   @db.Decimal(12, 2)
  totalInvested   Decimal   @db.Decimal(12, 2) // Computed by trigger: quantity * buyPrice
  currentValue    Decimal   @db.Decimal(12, 2) // Computed by trigger: quantity * currentPrice
  profitLoss      Decimal   @db.Decimal(12, 2) // Computed by trigger: currentValue - totalInvested
  purchaseDate    DateTime
  lastUpdated     DateTime
  metadata        Json?
  clientRequestId String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assetType])
  @@index([userId])
  @@index([deletedAt])
  @@schema("public")
}

model Loan {
  id                 String        @id @default(uuid())
  userId             String
  deviceId           String?
  type               String
  name               String
  principalAmount    Decimal       @db.Decimal(12, 2)
  outstandingBalance Decimal       @db.Decimal(12, 2) // Computed by trigger: principalAmount - sum(payments)
  interestRate       Decimal?      @db.Decimal(12, 2)
  emiAmount          Decimal?      @db.Decimal(12, 2)
  dueDate            DateTime?
  frequency          String?
  status             String        @default("active")
  contactPerson      String?
  syncStatus         String        @default("synced")
  clientRequestId    String?       @unique
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments           LoanPayment[]

  @@index([dueDate])
  @@index([status])
  @@index([syncStatus])
  @@index([userId])
  @@index([createdAt])
  @@index([deletedAt])
  @@schema("public")
}

model LoanPayment {
  id        String    @id @default(uuid())
  loanId    String
  amount    Decimal   @db.Decimal(12, 2)
  accountId String?
  date      DateTime
  notes     String?
  createdAt DateTime  @default(now())
  deletedAt DateTime? // Added for soft-delete consistency
  loan      Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([loanId])
  @@index([deletedAt])
  @@schema("public")
}

model Notification {
  id               String    @id @default(uuid())
  userId           String
  sourceUserId     String? // User who triggered the notification (for group messages, friend requests, etc.)
  title            String
  message          String
  type             String    @default("info") // friend_request, group_expense, loan_reminder, etc.
  category         String?
  deepLink         String?
  priority         String    @default("normal") // high, normal, low
  channels         Json      @default("[\"app\"]") // JSON array: ["app", "email", "push"]
  metadata         Json?
  // Multi-channel Delivery Tracking
  deliveryStatus   Json      @default("{}") // JSON: {app: sent, email: queued, push: failed}
  encryptedPayload String? // Optional encrypted payload (if E2E encryption enabled)
  isRead           Boolean   @default(false)
  createdAt        DateTime  @default(now())
  readAt           DateTime?
  deletedAt        DateTime? // Soft-delete for compliance
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([isRead])
  @@index([userId])
  @@index([sourceUserId])
  @@index([type])
  @@index([deletedAt])
  @@index([userId, isRead, createdAt]) // unread notification counts + sorted feed
  @@schema("public")
}

model Payment {
  id            String         @id @default(uuid())
  sessionId     String         @unique
  clientId      String
  advisorId     String
  amount        Decimal        @db.Decimal(12, 2)
  currency      String         @default("USD")
  status        String         @default("pending")
  paymentMethod String?
  transactionId String?
  description   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  advisor       User           @relation("Payment_advisorIdToUser", fields: [advisorId], references: [id], onDelete: Cascade)
  client        User           @relation("Payment_clientIdToUser", fields: [clientId], references: [id], onDelete: Cascade)
  session       AdvisorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([advisorId])
  @@index([clientId])
  @@index([createdAt])
  @@index([status])
  @@schema("public")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("public")
}

model SyncQueue {
  id             String    @id @default(uuid())
  userId         String
  deviceId       String?
  entityType     String // transaction, group, friend, goal, etc.
  entityId       String
  operation      String? // create, update, delete
  action         String?
  sourceDeviceId String?
  metadata       Json?
  data           Json? // JSON payload (was String? – changed to Json for type safety)
  status         String    @default("pending") // pending, processing, synced, failed
  errorMessage   String?
  retryCount     Int       @default(0)
  maxRetries     Int       @default(3) // Auto-fail after 3 retries
  processingTime Int? // Time in milliseconds to process
  createdAt      DateTime  @default(now())
  processedAt    DateTime?

  @@index([createdAt])
  @@index([deviceId])
  @@index([entityType])
  @@index([status])
  @@index([userId])
  @@schema("public")
}

model Todo {
  id        String   @id @default(uuid())
  title     String
  completed Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("public")
}

model Transaction {
  id                  String        @id @default(uuid())
  userId              String
  deviceId            String?
  accountId           String
  type                String
  amount              Decimal       @db.Decimal(12, 2)
  category            String
  subcategory         String?
  description         String?
  merchant            String?
  date                DateTime
  tags                Json? // JSON array of tag strings
  attachment          String?
  transferToAccountId String?
  transferType        String?
  expenseMode         String?
  groupExpenseId      String?
  groupName           String?
  splitType           String?
  importSource        String?
  importMetadata      String?
  originalCategory    String?
  importedAt          DateTime?
  dedupHash           String?       @unique
  version             Int           @default(1)
  synced              Boolean       @default(false)
  syncStatus          String        @default("synced")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?
  account             Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  groupExpense        GroupExpense? @relation(fields: [groupExpenseId], references: [id])
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([category])
  @@index([date])
  @@index([groupExpenseId])
  @@index([syncStatus])
  @@index([userId])
  @@index([userId, date])
  @@index([userId, type, date]) // dashboard monthly totals (income/expense by date range)
  @@index([userId, category, date]) // category breakdown queries
  @@index([userId, accountId, date]) // account-level transaction queries
  @@index([userId, deletedAt, date]) // soft-delete filtered date queries
  @@index([deletedAt])
  @@schema("public")
}

model User {
  id                    String                 @id @default(uuid())
  email                 String                 @unique
  name                  String
  password              String
  role                  String                 @default("user")
  status                String                 @default("verified")
  isApproved            Boolean                @default(false)
  firstName             String?
  lastName              String?
  salary                Decimal?               @db.Decimal(12, 2)
  dateOfBirth           DateTime?
  jobType               String?
  lastSynced            DateTime?
  syncToken             String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  avatarId              String?
  city                  String?
  country               String?
  gender                String?
  state                 String?
  accounts              Account[]
  advisorAvailability   AdvisorAvailability[]
  sessionsAsAdvisor     AdvisorSession[]       @relation("AdvisorSession_advisorIdToUser")
  sessionsAsClient      AdvisorSession[]       @relation("AdvisorSession_clientIdToUser")
  bookingsAsAdvisor     BookingRequest[]       @relation("BookingRequest_advisorIdToUser")
  bookingsAsClient      BookingRequest[]       @relation("BookingRequest_clientIdToUser")
  categories            Category[]
  chatMessages          ChatMessage[]
  devices               Device[]
  expenseBills          ExpenseBill[]
  friends               Friend[]
  goals                 Goal[]
  goalContributions     GoalContribution[]
  importLogs            ImportLog[]
  investments           Investment[]
  loans                 Loan[]
  notifications         Notification[]
  paymentsAsAdvisor     Payment[]              @relation("Payment_advisorIdToUser")
  paymentsAsClient      Payment[]              @relation("Payment_clientIdToUser")
  refreshTokens         RefreshToken[]
  todos                 Todo[]
  transactions          Transaction[]
  userPin               UserPin?
  userSettings          UserSettings?
  otpCodes              OtpCode[]
  aiScans               AiScan[]
  groupExpenses         GroupExpense[]
  recurringTransactions RecurringTransaction[]
  budgets               Budget[]
  taxCalculations       TaxCalculation[]
  goldAssets            GoldAsset[]

  @@index([isApproved])
  @@index([role])
  @@index([role, isApproved]) // advisor approval queue queries
  @@schema("public")
}

model UserPin {
  id             String    @id @default(uuid())
  userId         String    @unique
  pinHash        String
  keyBackup      String?
  expiresAt      DateTime
  isActive       Boolean   @default(true)
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([isActive])
  @@index([userId])
  @@schema("public")
}

model UserSettings {
  id        String   @id @default(uuid())
  userId    String   @unique
  theme     String   @default("light")
  language  String   @default("en")
  currency  String   @default("USD")
  timezone  String   @default("UTC")
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("public")
}

model OtpCode {
  id        String   @id @default(uuid())
  userId    String
  code      String
  expiresAt DateTime
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@schema("public")
}

model AiScan {
  id            String   @id @default(uuid())
  userId        String
  billId        String?
  transactionId String?
  extractedJson String
  confidence    Float
  provider      String   @default("gemini")
  processingMs  Int?
  status        String   @default("completed")
  errorMessage  String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([billId])
  @@index([createdAt])
  @@schema("public")
}

model ai_events {
  id            String   @id
  user_id       String
  event_type    String
  metadata_json Json
  created_at    DateTime @default(now())

  @@index([created_at], map: "idx_ai_events_created_at")
  @@index([event_type], map: "idx_ai_events_type")
  @@index([user_id], map: "idx_ai_events_user_id")
  @@schema("public")
}

model ai_insights {
  id                String   @id
  user_id           String
  insight_type      String
  insight_data_json Json
  confidence_score  Float
  created_at        DateTime @default(now())

  @@index([created_at], map: "idx_ai_insights_created_at")
  @@index([insight_type], map: "idx_ai_insights_type")
  @@index([user_id], map: "idx_ai_insights_user_id")
  @@schema("public")
}

model ai_model_runs {
  id              String    @id
  run_type        String
  status          String
  started_at      DateTime  @default(now())
  completed_at    DateTime?
  processed_users Int       @default(0)
  notes           String?

  @@index([started_at], map: "idx_ai_runs_started_at")
  @@index([run_type], map: "idx_ai_runs_type")
  @@schema("public")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  resource  String
  status    String
  ip        String?
  userAgent String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@schema("public")
}

model GroupExpense {
  id                   String               @id @default(uuid())
  userId               String
  deviceId             String?
  name                 String
  totalAmount          Decimal              @db.Decimal(12, 2)
  paidBy               String?
  date                 DateTime
  members              String? // DEPRECATED: Use GroupExpenseMember relation instead
  items                String?
  description          String?
  category             String?
  subcategory          String?
  splitType            String?
  yourShare            Decimal?             @db.Decimal(12, 2)
  expenseTransactionId String?
  createdBy            String?
  createdByName        String?
  status               String?
  notificationStatus   String?
  syncStatus           String               @default("synced")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  deletedAt            DateTime?
  transactions         Transaction[]
  paidByAccount        Account?             @relation(fields: [paidBy], references: [id])
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupMembers         GroupExpenseMember[] // New relational structure

  @@index([date])
  @@index([paidBy])
  @@index([syncStatus])
  @@index([userId])
  @@map("group_expenses")
  @@schema("public")
}

model GroupExpenseMember {
  id             String       @id @default(uuid())
  groupExpenseId String
  userId         String? // Optional: may be a friend without user account
  name           String // Display name
  email          String?
  phone          String?
  shareAmount    Decimal      @default(0) @db.Decimal(12, 2)
  hasPaid        Boolean      @default(false)
  paidAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  groupExpense   GroupExpense @relation(fields: [groupExpenseId], references: [id], onDelete: Cascade)

  @@index([groupExpenseId])
  @@index([userId])
  @@index([deletedAt])
  @@schema("public")
}

model user_features {
  user_id           String   @id
  avg_spend         Decimal  @db.Decimal(12, 2)
  monthly_income    Decimal  @db.Decimal(12, 2)
  savings_rate      Decimal  @db.Decimal(12, 2)
  top_category      String
  risk_score        Float
  peak_day          String
  feature_data_json Json
  updated_at        DateTime @default(now())

  @@schema("public")
}

model profiles {
  id               String    @id @db.Uuid
  email            String?   @unique
  full_name        String?
  first_name       String?
  last_name        String?
  avatar_url       String?
  avatar_id        String?
  phone            String?
  gender           String?
  date_of_birth    DateTime? @db.Timestamptz(6)
  monthly_income   Decimal?  @db.Decimal
  annual_income    Decimal?  @db.Decimal
  job_type         String?
  country          String?
  state            String?
  city             String?
  // REMOVED: currency, language (moved to UserSettings - single source of truth)
  // REMOVED: pin_code (security: use UserPin.pinHash only)
  visible_features Json?
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  updated_at       DateTime? @updatedAt @db.Timestamptz(6)

  @@schema("public")
}

// ─── OTP Verification Module ────────────────────────────────────────────────────

model OtpRequest {
  id          String    @id @default(uuid())
  userId      String?
  destination String // phone or email
  channel     String // 'sms' | 'email'
  purpose     String // 'signup' | 'login' | 'reset_password' | 'aa_consent' | 'sensitive_action'
  otpHash     String // SHA-256 hash of OTP (never store plaintext)
  expiryTime  DateTime
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  status      String    @default("ACTIVE") // ACTIVE | VERIFIED | EXPIRED | BLOCKED
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())
  verifiedAt  DateTime?

  @@index([destination, purpose, status])
  @@index([userId])
  @@index([createdAt])
  @@map("otp_requests")
  @@schema("public")
}

// ─── Account Aggregator (AA) Module — RBI Compliant ────────────────────────────

model AaConsent {
  id            String    @id @default(uuid())
  userId        String
  consentHandle String?
  consentId     String?   @unique
  vua           String? // Virtual User Address
  status        String    @default("CREATED") // CREATED | PENDING | READY | ACTIVE | REVOKED | EXPIRED | REJECTED
  purpose       String? // JSON: { code, text }
  fiTypes       String? // JSON array: ["DEPOSIT", "MUTUAL_FUNDS"]
  consentTypes  String? // JSON array: ["TRANSACTIONS", "SUMMARY"]
  dataFrom      DateTime?
  dataTo        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([consentHandle])
  @@index([status])
  @@map("aa_consent")
  @@schema("public")
}

model AaConsentArtifact {
  id           String   @id @default(uuid())
  consentId    String   @unique
  artifactJson String? // Full consent object JSON
  signature    String? // Base64 signed consent
  status       String?
  createdAt    DateTime @default(now())

  @@map("aa_consent_artifact")
  @@schema("public")
}

model AaDataSession {
  id            String   @id @default(uuid())
  consentId     String
  sessionId     String   @unique
  sessionStatus String   @default("ACTIVE") // ACTIVE | COMPLETED | EXPIRED | FAILED
  userId        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([consentId])
  @@index([userId])
  @@map("aa_data_session")
  @@schema("public")
}

model AaFinancialData {
  id                  String   @id @default(uuid())
  userId              String
  consentId           String
  sessionId           String
  accountType         String? // DEPOSIT, MUTUAL_FUNDS, etc.
  maskedAccountNumber String?
  dataJson            String? // Raw FI data JSON
  createdAt           DateTime @default(now())

  @@index([userId])
  @@index([consentId])
  @@map("aa_financial_data")
  @@schema("public")
}

model AaTransaction {
  id                  String   @id @default(uuid())
  userId              String
  consentId           String
  transactionDate     DateTime
  amount              Decimal  @db.Decimal(12, 2)
  type                String // debit | credit
  description         String?
  maskedAccountNumber String?
  createdAt           DateTime @default(now())

  @@index([userId])
  @@index([consentId])
  @@index([transactionDate])
  @@map("aa_transactions")
  @@schema("public")
}

// ─── Recurring Transactions (Subscriptions & Bills) ────────────────────────────

model RecurringTransaction {
  id              String    @id @default(uuid())
  userId          String
  title           String
  amount          Decimal   @db.Decimal(12, 2)
  category        String
  subcategory     String?
  interval        String    @default("monthly") // weekly, monthly, yearly
  nextDueDate     DateTime
  autoProcess     Boolean   @default(false)
  status          String    @default("active") // active, paused, cancelled
  accountId       String?
  description     String?
  merchant        String?
  lastProcessedAt DateTime?
  clientRequestId String?   @unique
  syncStatus      String    @default("synced")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([nextDueDate])
  @@index([syncStatus])
  @@index([deletedAt])
  @@map("recurring_transactions")
  @@schema("public")
}

// ─── Budgets & Budget Alerts ───────────────────────────────────────────────────

model Budget {
  id              String    @id @default(uuid())
  userId          String
  category        String
  amount          Decimal   @db.Decimal(12, 2)
  spent           Decimal   @default(0) @db.Decimal(12, 2)
  period          String    @default("monthly") // weekly, monthly, yearly
  threshold       Int       @default(80) // Alert percentage threshold (0-100)
  startDate       DateTime?
  endDate         DateTime?
  alertEnabled    Boolean   @default(true)
  alertChannels   Json      @default("[\"app\"]") // ["app", "email", "push"]
  clientRequestId String?   @unique
  syncStatus      String    @default("synced")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, period])
  @@index([userId])
  @@index([category])
  @@index([period])
  @@index([syncStatus])
  @@index([deletedAt])
  @@map("budgets")
  @@schema("public")
}

// ─── Tax Calculations ──────────────────────────────────────────────────────────

model TaxCalculation {
  id              String    @id @default(uuid())
  userId          String
  year            Int
  regime          String? // 'standard', 'new', 'old', 'single', 'married'
  country         String    @default("India")
  totalIncome     Decimal   @db.Decimal(12, 2)
  totalExpense    Decimal   @db.Decimal(12, 2)
  netProfit       Decimal   @db.Decimal(12, 2)
  taxableIncome   Decimal   @db.Decimal(12, 2)
  estimatedTax    Decimal   @db.Decimal(12, 2)
  taxRate         Decimal   @db.Decimal(5, 2)
  deductions      Decimal   @default(0) @db.Decimal(12, 2)
  currency        String    @default("INR")
  notes           String?
  metadata        Json?
  clientRequestId String?   @unique
  syncStatus      String    @default("synced")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([year])
  @@index([deletedAt])
  @@map("tax_calculations")
  @@schema("public")
}

// ─── Gold & Precious Metal Assets ──────────────────────────────────────────────

model GoldAsset {
  id                String    @id @default(uuid())
  userId            String
  type              String    @default("gold") // gold, jewelry, coin
  quantity          Decimal   @db.Decimal(12, 4)
  unit              String    @default("gram") // gram, ounce, kg
  purchasePrice     Decimal   @db.Decimal(12, 2)
  currentPrice      Decimal   @db.Decimal(12, 2)
  purchaseDate      DateTime
  purityPercentage  Decimal   @default(99.9) @db.Decimal(5, 2)
  location          String?
  certificateNumber String?
  notes             String?
  clientRequestId   String?   @unique
  syncStatus        String    @default("synced")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([syncStatus])
  @@index([deletedAt])
  @@map("gold_assets")
  @@schema("public")
}
